{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local/orchestrator/agent-registry.schema.json",
  "title": "Agent Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_version",
    "workspace_id",
    "agents",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "registry_version": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9_.:-]+$"
    },
    "agents": {
      "type": "array",
      "items": {
        "$ref": "agent.schema.json"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}