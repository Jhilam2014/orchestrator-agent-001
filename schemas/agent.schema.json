{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local/orchestrator/agent.schema.json",
  "title": "Generated Agent Specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "agent_name",
    "level",
    "domain",
    "purpose",
    "responsibilities",
    "inputs",
    "outputs",
    "tools_allowed",
    "dependencies",
    "constraints",
    "success_criteria",
    "handoff_contract",
    "validation_rules",
    "termination_condition"
  ],
  "properties": {
    "agent_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9_.:-]+$"
    },
    "agent_name": {
      "type": "string",
      "minLength": 2
    },
    "level": {
      "type": "string",
      "enum": [
        "level_1_sme",
        "level_2_lead",
        "level_3_implementation",
        "level_4_reviewer_validator"
      ]
    },
    "domain": {
      "type": "string",
      "minLength": 2
    },
    "purpose": {
      "type": "string",
      "minLength": 5
    },
    "responsibilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tools_allowed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-zA-Z0-9_.:-]+$"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "success_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "handoff_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_contract",
        "output_contract",
        "handoff_to",
        "handoff_from"
      ],
      "properties": {
        "input_contract": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "output_contract": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "handoff_to": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9_.:-]+$"
          }
        },
        "handoff_from": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9_.:-]+$"
          }
        }
      }
    },
    "validation_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "termination_condition": {
      "type": "string",
      "minLength": 5
    }
  }
}