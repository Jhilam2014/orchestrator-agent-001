{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local/orchestrator/agent.schema.json",
  "title": "Generated Agent Specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "agent_name",
    "level",
    "domain",
    "purpose",
    "responsibilities",
    "inputs",
    "outputs",
    "tools_allowed",
    "dependencies",
    "constraints",
    "success_criteria",
    "handoff_contract",
    "validation_rules",
    "termination_condition",
    "agent_type",
    "lifecycle",
    "provenance",
    "human_review"
  ],
  "properties": {
    "agent_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9_.:-]+$"
    },
    "agent_name": {
      "type": "string",
      "minLength": 2
    },
    "level": {
      "type": "string",
      "enum": [
        "level_0_human_controller",
        "level_1_sme",
        "level_2_lead",
        "level_3_implementation",
        "level_4_reviewer_validator"
      ]
    },
    "domain": {
      "type": "string",
      "minLength": 2
    },
    "purpose": {
      "type": "string",
      "minLength": 5
    },
    "responsibilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tools_allowed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-zA-Z0-9_.:-]+$"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "success_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "handoff_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_contract",
        "output_contract",
        "handoff_to",
        "handoff_from"
      ],
      "properties": {
        "input_contract": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "output_contract": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "handoff_to": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9_.:-]+$"
          }
        },
        "handoff_from": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9_.:-]+$"
          }
        }
      }
    },
    "validation_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "termination_condition": {
      "type": "string",
      "minLength": 5
    },
    "agent_type": {
      "type": "string",
      "enum": [
        "ai_generated",
        "human_custom",
        "human_controller",
        "system_internal",
        "reviewer_validator"
      ]
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "created_by",
        "requires_human_approval",
        "last_decision"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "pending_human_review",
            "active",
            "disabled",
            "archived",
            "rejected",
            "needs_revision"
          ]
        },
        "created_by": {
          "type": "string",
          "minLength": 1
        },
        "requires_human_approval": {
          "type": "boolean"
        },
        "last_decision": {
          "type": "string",
          "enum": [
            "none",
            "approved",
            "approved_with_changes",
            "rejected",
            "needs_revision",
            "custom_agent_added",
            "disabled",
            "archived"
          ]
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "created_at",
        "updated_at",
        "version"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "orchestrator_generated",
            "human_authored",
            "human_modified",
            "imported",
            "system_default"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "human_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "review_status",
        "reviewer_role",
        "change_summary",
        "approval_gate_id"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "not_required",
            "pending",
            "approved",
            "approved_with_changes",
            "rejected",
            "needs_revision"
          ]
        },
        "reviewer_role": {
          "type": "string"
        },
        "change_summary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approval_gate_id": {
          "type": "string"
        }
      }
    }
  }
}