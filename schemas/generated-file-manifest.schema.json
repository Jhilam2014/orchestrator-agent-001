{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/generated-file-manifest.schema.json",
  "title": "Generated File Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflowId",
    "generatedAt",
    "files",
    "validation"
  ],
  "properties": {
    "workflowId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "artifactType",
          "rootFolder",
          "purpose",
          "generatedBy",
          "status"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "artifactType": {
            "type": "string"
          },
          "rootFolder": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "generatedBy": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "created",
              "updated",
              "skipped",
              "failed"
            ]
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allFilesUnderAllowedRootFolders",
        "reservedFolderViolationCount",
        "missingRequiredArtifactCount"
      ],
      "properties": {
        "allFilesUnderAllowedRootFolders": {
          "type": "boolean"
        },
        "reservedFolderViolationCount": {
          "type": "integer",
          "minimum": 0
        },
        "missingRequiredArtifactCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
