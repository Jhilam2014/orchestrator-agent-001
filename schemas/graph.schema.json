{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local/orchestrator/graph.schema.json",
  "title": "Workspace Graph Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "graph_id",
    "nodes",
    "relationships"
  ],
  "properties": {
    "graph_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9_.:-]+$"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "name",
          "properties"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9_.:-]+$"
          },
          "type": {
            "type": "string",
            "enum": [
              "Workspace",
              "Workflow",
              "Task",
              "Agent",
              "Service",
              "API",
              "Endpoint",
              "Database",
              "Table",
              "Collection",
              "GraphNode",
              "VectorIndex",
              "Component",
              "Page",
              "DesignAsset",
              "Runtime",
              "Tool",
              "Integration",
              "Infrastructure",
              "EnvironmentVariable",
              "Test",
              "ChangeHistory",
              "DecisionRecord",
              "UserRequirement",
              "Risk",
              "CostEvaluation"
            ]
          },
          "name": {
            "type": "string"
          },
          "properties": {
            "type": "object",
            "additionalProperties": {
              "type": [
                "string",
                "number",
                "boolean",
                "null"
              ]
            }
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "from",
          "to",
          "type",
          "properties"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9_.:-]+$"
          },
          "from": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9_.:-]+$"
          },
          "to": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9_.:-]+$"
          },
          "type": {
            "type": "string",
            "enum": [
              "OWNS",
              "DEPENDS_ON",
              "IMPLEMENTS",
              "GENERATED_BY",
              "REPORTS_TO",
              "STORES_IN",
              "CONNECTS_TO",
              "MANAGED_BY",
              "MODIFIED_BY",
              "REUSES",
              "EVOLVES_FROM",
              "VALIDATES",
              "EXPOSES",
              "CONSUMES",
              "PRODUCES",
              "TRIGGERS",
              "BLOCKS",
              "APPROVES",
              "OBSERVES"
            ]
          },
          "properties": {
            "type": "object",
            "additionalProperties": {
              "type": [
                "string",
                "number",
                "boolean",
                "null"
              ]
            }
          }
        }
      }
    }
  }
}