{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local/orchestrator/task.schema.json",
  "title": "Task Decomposition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "title",
    "description",
    "owner",
    "status",
    "priority",
    "dependencies",
    "inputs",
    "outputs",
    "acceptance_criteria",
    "validation_steps"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9_.:-]+$"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "owner": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9_.:-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "ready",
        "in_progress",
        "blocked",
        "done",
        "failed",
        "cancelled"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-zA-Z0-9_.:-]+$"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}